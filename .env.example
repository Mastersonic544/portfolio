# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Vercel Analytics — find in Vercel dashboard → Settings → Tokens
# Project ID is in your Vercel project URL or Settings → General
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=

# Cloudinary image uploads (free, no billing required)
# Cloud name: cloudinary.com/console → top-left of dashboard
# Upload preset: Settings → Upload → Upload presets → Add preset → Signing mode: Unsigned
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_PRESET=

# Gmail SMTP — generate at: Google Account → Security → 2-Step Verification → App passwords
# App name: "Portfolio" — copy the 16-char code (no spaces)
GMAIL_APP_PASSWORD=
